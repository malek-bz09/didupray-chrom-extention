{
  "manifest_version": 3,
  "name": "DIDUPRAY",
  "version": "1.0",

  "action": {
    "default_popup": "popup.html"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "storage",
    "tabs",
    "notifications",
    "alarms",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "https://api.aladhan.com/*",
    "*://*.youtube.com/*",
    "*://*.instagram.com/*",
    "*://*.tiktok.com/*",
    "*://*.facebook.com/*",
    "*://*.x.com/*",
    "*://*.twitter.com/*"
  ],
  "web_accessible_resources": [
    {
      "resources": ["blocked.html"],
      "matches": ["<all_urls>"]
    }
  ]
}
